# Sourced from .zprofile (zsh login) and .bash_profile (bash login).
# Not expected to be sourced from POSIX sh.

# Make non-interactive bash children load mise/brew via ~/.bash_env.
export BASH_ENV="$HOME/.bash_env"

. "$HOME/.shell-helpers.sh"

if [ -n "$ZSH_VERSION" ]; then
  # Zsh handles mise itself: shims in .zshenv (non-interactive), hooks in
  # .zshrc (interactive).
  activate_brew zsh
else
  activate_brew bash
  if type mise > /dev/null 2>&1; then
    eval "$(mise activate bash --shims)"
  fi
fi
